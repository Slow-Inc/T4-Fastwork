# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_PROJECT_REF=<ref>
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_ANON_KEY=

# Postgres for Drizzle — Supavisor TRANSACTION pooler (port 6543), not direct 5432.
DATABASE_URL=postgresql://postgres.<ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres

# LLM (OpenAI-compatible gateway)
CUSTOM_OPENAI_API_KEY=
CUSTOM_OPENAI_API_BASE=https://gateway.9arm.co/v1
CUSTOM_OPENAI_MODEL=qwen3.6-35b-a3b

# Embeddings (OpenAI-compatible). Dimension must match the vector(N) column in the schema.
# Decided: bge-m3 (multilingual, 1024-dim) via the 9arm gateway.
CUSTOM_OPENAI_EMBEDDING_MODEL=bge-m3
CUSTOM_OPENAI_EMBEDDING_DIM=1024
