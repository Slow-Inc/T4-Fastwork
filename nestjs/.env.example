# Copy to .env.local and fill in. .env.local is gitignored.
# Names here must match what the code reads (process.env.*).

# Server — CORS origin for the frontend, and the port to listen on. Both have
# defaults (http://localhost:3000, 4100); set them for non-local environments.
FRONTEND_ORIGIN=http://localhost:3000
PORT=4100

# Supabase — the runtime connects via DATABASE_URL below; the SUPABASE_* values
# are used by tooling (CLI/migrations) and kept here for reference.
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_PROJECT_REF=<ref>
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_ANON_KEY=

# Postgres connection for Drizzle — Supavisor TRANSACTION pooler (port 6543), NOT direct 5432.
# Copy the exact "Transaction pooler" URI from: Supabase Dashboard -> Project Settings -> Database
#   -> Connection string -> Transaction pooler, then replace [YOUR-PASSWORD] below.
# (The DB password is only shown at creation / can be reset in that same page — it is not retrievable via MCP.)
DATABASE_URL=postgresql://postgres.<ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres

# LLM (OpenAI-compatible gateway)
CUSTOM_OPENAI_API_KEY=
CUSTOM_OPENAI_API_BASE=https://gateway.9arm.co/v1
CUSTOM_OPENAI_MODEL=qwen3.6-35b-a3b

# Embeddings — SEPARATE endpoint from chat (serverless-friendly hosted API).
# Decided: Jina v3 (multilingual, 1024-dim = matches the vector(1024) schema).
# Free key (no card) at https://jina.ai/embeddings
CUSTOM_OPENAI_EMBEDDING_API_BASE=https://api.jina.ai/v1
CUSTOM_OPENAI_EMBEDDING_API_KEY=
CUSTOM_OPENAI_EMBEDDING_MODEL=jina-embeddings-v3
CUSTOM_OPENAI_EMBEDDING_DIM=1024

# Cloudflare Turnstile — feature-flagged: unset = the chat guard no-ops (dev/local).
TURNSTILE_SECRET=

# GitHub live team portfolio (ADR 0003 / live freshness #25).
# GITHUB_TOKEN — fine-grained PAT with read access to the org + members' public
#   repos; used for the GitHub REST fetches (unset = unauthenticated, low rate
#   limit + no org access). Set an expiry <= 366 days.
GITHUB_TOKEN=
# GITHUB_REFRESH_SECRET — shared secret guarding POST /github/refresh and
#   /github/heal (constant-time checked). The frontend uses the SAME value
#   (nextjs GITHUB_REFRESH_SECRET) for the R4 heal-on-read trigger, and the
#   github-refresh-cron Action uses it as the repo secret BACKEND_REFRESH_SECRET
#   (GitHub reserves the GITHUB_ prefix for Actions secrets). Unset = both
#   endpoints fail closed (reject every request).
GITHUB_REFRESH_SECRET=
# GITHUB_WEBHOOK_SECRET — HMAC secret for POST /github/webhook; must match the
#   secret configured on the Slow-Inc org webhook. Unset = webhook fails closed.
GITHUB_WEBHOOK_SECRET=