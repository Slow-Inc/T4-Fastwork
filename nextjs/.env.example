# Copy to .env.local and fill in. .env.local is gitignored.
# Names here must match what the code reads (process.env.*).

NEXT_PUBLIC_SITE_URL=https://t4labs.co

# Backend API base (Nest.js) — the browser calls it directly for chat SSE.
# Unset in local dev falls back to http://localhost:4100; set it per environment
# (e.g. the backend's Vercel URL) when deploying.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4100

# Shared secret for the stale-while-heal trigger (#25 R4). The Next SERVER (not
# the browser) POSTs /github/heal with this in the x-refresh-secret header when a
# live snapshot is stale. Must equal GITHUB_REFRESH_SECRET in nestjs/.env.local.
# Unset = heal is a no-op (pages still serve stale data, just no background heal).
GITHUB_REFRESH_SECRET=

# Supabase public "publishable" key (formerly "anon") — cookieless public reads + admin auth.
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Admin allow-list — comma-separated emails permitted into /admin.
ADMIN_EMAILS=

# Google Analytics 4 — feature-flagged: unset = no script loads.
NEXT_PUBLIC_GA_ID=

# Cloudflare Turnstile — feature-flagged: unset = the contact form submits without
# a token and the server-side check no-ops. TURNSTILE_SECRET must also be set in
# nestjs/.env.local for the chat endpoint's guard. Get keys at
# https://dash.cloudflare.com → Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=
